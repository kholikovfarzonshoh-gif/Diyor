#:kivy 2.3.0

<CalculatorScreen>:
    orientation: "vertical"
    padding: 12
    spacing: 8

    Label:
        text: root.display_text if root.display_text else "0"
        font_size: "32sp"
        size_hint_y: 0.2
        halign: "right"
        valign: "middle"
        text_size: self.size
        color: 0, 0, 0, 1
        canvas.before:
            Color:
                rgba: 0.93, 0.93, 0.93, 1
            Rectangle:
                pos: self.pos
                size: self.size

    GridLayout:
        cols: 4
        spacing: 6
        size_hint_y: 0.8

        Button:
            text: "C"
            on_release: root.on_key("C")
        Button:
            text: "("
            on_release: root.on_key("(")
        Button:
            text: ")"
            on_release: root.on_key(")")
        Button:
            text: "÷"
            on_release: root.on_key("÷")

        Button:
            text: "7"
            on_release: root.on_key("7")
        Button:
            text: "8"
            on_release: root.on_key("8")
        Button:
            text: "9"
            on_release: root.on_key("9")
        Button:
            text: "×"
            on_release: root.on_key("×")

        Button:
            text: "4"
            on_release: root.on_key("4")
        Button:
            text: "5"
            on_release: root.on_key("5")
        Button:
            text: "6"
            on_release: root.on_key("6")
        Button:
            text: "-"
            on_release: root.on_key("-")

        Button:
            text: "1"
            on_release: root.on_key("1")
        Button:
            text: "2"
            on_release: root.on_key("2")
        Button:
            text: "3"
            on_release: root.on_key("3")
        Button:
            text: "+"
            on_release: root.on_key("+")

        Button:
            text: "0"
            on_release: root.on_key("0")
        Button:
            text: "."
            on_release: root.on_key(".")
        Button:
            text: "⌫"
            on_release: root.on_key("⌫")
        Button:
            text: "="
            on_release: root.on_key("=")
            background_color: 0.3, 0.6, 0.9, 1


<TaskRow>:
    size_hint_y: None
    height: "44dp"
    spacing: 6

    Button:
        id: check_btn
        text: "✓"
        size_hint_x: 0.15

    Label:
        text: root.text
        halign: "left"
        valign: "middle"
        text_size: self.size
        shorten: True

    Button:
        id: del_btn
        text: "✕"
        size_hint_x: 0.15
        background_color: 0.85, 0.3, 0.3, 1


<PlannerScreen>:
    orientation: "vertical"
    padding: 12
    spacing: 8

    BoxLayout:
        size_hint_y: 0.08
        spacing: 6

        Button:
            text: "◀"
            size_hint_x: 0.15
            on_release: root.shift_day(-1)

        Label:
            text: root.current_date
            font_size: "18sp"

        Button:
            text: "▶"
            size_hint_x: 0.15
            on_release: root.shift_day(1)

        Button:
            text: "Сегодня"
            size_hint_x: 0.3
            on_release: root.go_today()

    BoxLayout:
        size_hint_y: 0.1
        spacing: 6

        TextInput:
            id: new_task_input
            hint_text: "Новая задача..."
            multiline: False
            on_text_validate: root.add_task(self.text)

        Button:
            text: "Добавить"
            size_hint_x: 0.3
            on_release: root.add_task(new_task_input.text)

    ScrollView:
        BoxLayout:
            id: task_list
            orientation: "vertical"
            size_hint_y: None
            height: self.minimum_height
            spacing: 4


<LegendRow>:
    size_hint_y: None
    height: "24dp"
    spacing: 6

    Widget:
        size_hint_x: 0.12
        canvas:
            Color:
                rgba: root.swatch_color
            Rectangle:
                pos: self.pos
                size: self.size

    Label:
        text: root.label_text
        halign: "left"
        text_size: self.size
        font_size: "13sp"


<FinanceScreen>:
    orientation: "vertical"
    padding: 12
    spacing: 8

    BoxLayout:
        size_hint_y: 0.28
        orientation: "vertical"
        spacing: 4

        BoxLayout:
            spacing: 6
            ToggleButton:
                id: income_btn
                text: "Доход"
                group: "tx_type"
            ToggleButton:
                id: expense_btn
                text: "Расход"
                group: "tx_type"
                state: "down"

        BoxLayout:
            spacing: 6
            TextInput:
                id: amount_input
                hint_text: "Сумма"
                multiline: False
                input_filter: "float"
            Spinner:
                id: category_spinner
                text: "Еда"
                values: ["Еда", "Транспорт", "Жильё", "Развлечения", "Здоровье", "Зарплата", "Подработка", "Другое"]

        BoxLayout:
            spacing: 6
            TextInput:
                id: note_input
                hint_text: "Заметка (необязательно)"
                multiline: False

            Button:
                text: "Добавить"
                size_hint_x: 0.35
                on_release:
                    root.add_transaction(amount_input.text, "Доход" if income_btn.state == "down" else "Расход", category_spinner.text, note_input.text)

    Label:
        text: root.summary_text
        size_hint_y: 0.06
        font_size: "15sp"
        bold: True

    BoxLayout:
        size_hint_y: 0.46
        spacing: 10

        ScrollView:
            size_hint_x: 0.5
            BoxLayout:
                id: tx_list
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                spacing: 4

        BoxLayout:
            size_hint_x: 0.5
            orientation: "vertical"

            PieChart:
                id: pie_chart
                size_hint_y: 0.7

            ScrollView:
                size_hint_y: 0.3
                BoxLayout:
                    id: legend_box
                    orientation: "vertical"
                    size_hint_y: None
                    height: self.minimum_height
